{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@popapp/theme/*": [
        "../registry/theme/*"
      ],
      "@popapp/components/*": [
        "../registry/components/*"
      ],
      "@popapp/hooks/*": [
        "../registry/hooks/*"
      ],
      "@popapp/utils/*": [
        "../registry/utils/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../registry/**/*.ts",
    "../registry/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
